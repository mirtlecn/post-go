# Redis connection URL redis://default:password@host:port
# e.g. redis://localhost:6379/0
# For TLS/SSL, use rediss:// instead of redis://
LINKS_REDIS_URL=redis://user:password@host:port/db-number

# Secret key for API authentication
SECRET_KEY=your-secret-key-here

# Public domain for generated links, without protocol or trailing slash
# e.g. www.example.com
# BASE_DOMAIN=www.example.com

# Optional base64-encoded HTML footer for rendered Markdown pages
# Invalid base64 or blank decoded HTML is ignored.
# Generate with: printf '%s' '<footer html>' | base64 | tr -d '\n'
# FOOTER=<base64-encoded HTML footer>

# Port | default is 3000
# PORT=3000

# Limits
# Max text size in KB | default is 1024kb
# MAX_CONTENT_SIZE_KB=1024

# S3 Configuration (for file uploads)
# S3_ENDPOINT=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_BUCKET_NAME=
# S3_REGION=auto
# S3_FORCE_PATH_STYLE=true

# S3 max file upload size in MB | default is 3.5mb
# MAX_FILE_SIZE_MB=3.5

POST_DEBUG=false
