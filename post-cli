#!/bin/sh
set -e

if [ -z "${POST_HOST}" ] || [ -z "${POST_TOKEN}" ]; then
  printf 'error: POST_HOST and POST_TOKEN environment variables must be set.\n' >&2
  exit 1
fi

POST_HOST="${POST_HOST}"
POST_TOKEN="${POST_TOKEN}"

# ══════════════════════════════════════════════════════════════
# Helpers
# ══════════════════════════════════════════════════════════════

die() {
  printf 'error: %s\n' "$*" >&2
  exit 1
}

require_cmds() {
  for _cmd in curl jq; do
    command -v "$_cmd" >/dev/null 2>&1 || die "'$_cmd' is required but not found"
  done
}

# ── clipboard ─────────────────────────────────────────────────

clipboard_copy() {
  if command -v pbcopy >/dev/null 2>&1; then
    printf '%s' "$1" | pbcopy
  elif command -v xclip >/dev/null 2>&1; then
    printf '%s' "$1" | xclip -selection clipboard
  elif command -v xsel >/dev/null 2>&1; then
    printf '%s' "$1" | xsel --clipboard --input
  else
    printf 'warning: no clipboard write tool found (pbcopy/xclip/xsel)\n' >&2
    return 1
  fi
}

clipboard_paste() {
  if command -v pbpaste >/dev/null 2>&1; then
    pbpaste
  elif command -v xclip >/dev/null 2>&1; then
    xclip -selection clipboard -o
  elif command -v xsel >/dev/null 2>&1; then
    xsel --clipboard --output
  else
    die "no clipboard read tool found (pbpaste/xclip/xsel)"
  fi
}

# ── pretty-print JSON ─────────────────────────────────────────

print_json() {
  printf '%s' "$1" | jq .
}

# ── auth header ───────────────────────────────────────────────

auth_header() {
  printf 'Authorization: Bearer %s' "$POST_TOKEN"
}

http_request() {
  _method="$1"
  _path="$2"
  shift 2
  _tmp=$(mktemp) || die "failed to create temp file"

  set +e
  _status=$(curl -sS -o "$_tmp" -w "%{http_code}" -X "$_method" "${POST_HOST}${_path}" "$@")
  _curl_rc=$?
  set -e

  if [ "$_curl_rc" -ne 0 ]; then
    _body=$(cat "$_tmp" 2>/dev/null || true)
    rm -f "$_tmp"
    [ -n "$_body" ] && printf '%s\n' "$_body" >&2
    die "request failed: ${_method} ${POST_HOST}${_path} (curl exit ${_curl_rc})"
  fi

  _body=$(cat "$_tmp" 2>/dev/null || true)
  rm -f "$_tmp"

  if [ "$_status" -ge 400 ]; then
    if printf '%s' "$_body" | jq -e '.error' >/dev/null 2>&1; then
      _errmsg=$(printf '%s' "$_body" | jq -r '.error')
      _hint=$(printf '%s' "$_body" | jq -r '.hint // empty')
      if [ -n "$_hint" ]; then
        die "API error: $_errmsg — $_hint"
      fi
      die "API error: $_errmsg"
    fi
    if [ -n "$_body" ]; then
      die "HTTP ${_status}: $_body"
    fi
    die "HTTP ${_status}: empty response"
  fi

  printf '%s' "$_body"
}

curl_json() {
  _method="$1"
  _path="$2"
  _body="$3"
  shift 3
  http_request "$_method" "$_path" \
    -H "$(auth_header)" \
    -H "Content-Type: application/json" \
    "$@" \
    --data-binary "$_body"
}

# ══════════════════════════════════════════════════════════════
# API calls
# ══════════════════════════════════════════════════════════════

# api_post_new <content> <slug> <ttl> <type> <convert> <method> <export>
# Uploads content and returns the API response JSON.
# method: POST (fail on conflict) | PUT (overwrite)
api_post_new() {
  _content="$1"
  _slug="$2"
  _ttl="$3"
  _type="$4"
  _convert="$5"
  _method="${6:-POST}"
  _export="${7:-0}"

  # Build payload via a pipe to avoid arg length limits
  _resp=$(
    if [ "$_export" = "1" ]; then
      _body=$(
        printf '{"url":'
        printf '%s' "$_content" | jq -Rs .
        [ -n "$_slug"    ] && printf ',"path":"%s"' "$_slug"
        [ -n "$_ttl"     ] && printf ',"ttl":%s'   "$_ttl"
        [ -n "$_type"    ] && printf ',"type":"%s"' "$_type"
        [ -n "$_convert" ] && printf ',"convert":"%s"' "$_convert"
        printf '}'
      )
      curl_json "$_method" "/" "$_body" -H "X-Export: true"
    else
      _body=$(
        printf '{"url":'
        printf '%s' "$_content" | jq -Rs .
        [ -n "$_slug"    ] && printf ',"path":"%s"' "$_slug"
        [ -n "$_ttl"     ] && printf ',"ttl":%s'   "$_ttl"
        [ -n "$_type"    ] && printf ',"type":"%s"' "$_type"
        [ -n "$_convert" ] && printf ',"convert":"%s"' "$_convert"
        printf '}'
      )
      curl_json "$_method" "/" "$_body"
    fi
  )

  printf '%s\n' "$_resp"
}

# api_ls [path] [export]
api_ls() {
  if [ -n "$1" ]; then
    _body=$(printf '{"path":%s}' "$(printf '%s' "$1" | jq -Rs .)")
    if [ "$2" = "1" ]; then
      curl_json GET "/" "$_body" -H "X-Export: true"
    else
      curl_json GET "/" "$_body"
    fi
  else
    if [ "$2" = "1" ]; then
      http_request GET "/" \
        -H "$(auth_header)" \
        -H "X-Export: true"
    else
      http_request GET "/" -H "$(auth_header)"
    fi
  fi
}

# api_export [path]
api_export() {
  api_ls "$1" 1
}

# api_rm <path> [export]
api_rm() {
  _body=$(printf '{"path":%s}' "$(printf '%s' "$1" | jq -Rs .)")
  if [ "$2" = "1" ]; then
    curl_json DELETE "/" "$_body" -H "X-Export: true"
  else
    curl_json DELETE "/" "$_body"
  fi
}

# api_post_file <filepath> <slug> <ttl> <method> <export>
# Uploads a binary file via multipart/form-data and returns the API response JSON.
api_post_file() {
  _fp="$1"
  _slug="$2"
  _ttl="$3"
  _method="${4:-POST}"
  _export="${5:-0}"

  _resp=$(
    if [ "$_export" = "1" ]; then
      http_request "$_method" "/" \
        -H "$(auth_header)" \
        -H "X-Export: true" \
        -F "file=@${_fp}" \
        ${_slug:+-F "path=${_slug}"} \
        ${_ttl:+-F "ttl=${_ttl}"}
    else
      http_request "$_method" "/" \
        -H "$(auth_header)" \
        -F "file=@${_fp}" \
        ${_slug:+-F "path=${_slug}"} \
        ${_ttl:+-F "ttl=${_ttl}"}
    fi
  )

  printf '%s\n' "$_resp"
}

# ══════════════════════════════════════════════════════════════
# Commands
# ══════════════════════════════════════════════════════════════

cmd_new() {
  # ── parse options ──────────────────────────────────────────
  _slug=""
  _ttl=""
  _confirm=1
  _file=""
  _convert=""
  _method="POST"
  _export=0

  while [ $# -gt 0 ]; do
    case "$1" in
      -s|--slug)
        [ -n "$2" ] || die "option $1 requires a value"
        _slug="$2"; shift 2 ;;
      -t|--ttl)
        [ -n "$2" ] || die "option $1 requires a number (minutes)"
        _ttl="$2"; shift 2 ;;
      -u|--update)
        _method="PUT"; shift ;;
      -y|--no-confirm)
        _confirm=0; shift ;;
      -x|--export)
        _export=1; shift ;;
      -f|--file)
        [ -n "$2" ] || die "option $1 requires a file path"
        _file="$2"; shift 2 ;;
      -c|--convert)
        [ -n "$2" ] || die "option $1 requires a value: html|md2html|url|text|qrcode|file"
        case "$2" in
          html|md2html|url|text|qrcode|file) ;;
          *) die "invalid convert value '$2'. Must be one of: html, md2html, url, text, qrcode, file" ;;
        esac
        _convert="$2"; shift 2 ;;
      --)
        shift; break ;;
      -*)
        die "unknown option '$1'. Try: post help" ;;
      *)
        break ;;
    esac
  done

  # ── resolve content & label ───────────────────────────────
  # file 模式：必须指定 -f，不接受文本/剪贴板/stdin
  if [ "$_convert" = "file" ]; then
    [ -n "$_file" ] || die "-c file requires -f <path>"
    [ -f "$_file" ] || die "file not found: $_file"
    _label="[File upload]: $_file"
    _content="$_file"   # 仅用于 confirm 显示，实际上传由 api_post_file 处理
  elif [ -n "$_file" ]; then
    [ -f "$_file" ] || die "file not found: $_file"
    _content=$(cat "$_file")
    _label="[File]: $_file"
  elif [ $# -gt 0 ]; then
    _content="$*"
    _label="[Text&Link]: $*"
  elif [ ! -t 0 ]; then
    _content=$(cat)
    _label="[Pipe]"
  else
    # no args, no stdin → read clipboard
    _content=$(clipboard_paste)
    _label="[Clipboard]"
  fi

  [ -n "$_content" ] || die "content is empty"

  # ── convert (服务端处理，客户端仅设置类型) ──────────────────
  _type=""
  case "$_convert" in
    qrcode|md2html)
      # 不做本地转换，传递给服务端处理
      ;;
    html|url|text)
      _type="$_convert"
      ;;
  esac

  # ── confirm ───────────────────────────────────────────────
  if [ "$_confirm" = "1" ]; then
    printf '%s\n' "$_label" >&2
    [ -n "$_slug"    ] && printf '[Slug]: %s\n'             "$_slug"    >&2
    [ -n "$_ttl"     ] && printf '[Expire after]: %s min\n' "$_ttl"     >&2
    [ -n "$_convert" ] && printf '[Convert]: %s\n'          "$_convert" >&2
    [ -n "$_type"    ] && printf '[Type]: %s\n'             "$_type"    >&2
    [ "$_export" = "1" ] && printf '[Export]: full response\n'          >&2
    [ "$_method" = "PUT" ] && printf '[Mode]: overwrite\n'              >&2
    printf '[Post on]: %s? (y/N) ' "$POST_HOST" >&2
    read -r _answer </dev/tty
    case "$_answer" in
      [yY]|[yY][eE][sS]) ;;
      *) printf 'Aborted.\n' >&2; exit 0 ;;
    esac
  fi

  # ── upload ────────────────────────────────────────────────
  if [ "$_convert" = "file" ]; then
    _resp=$(api_post_file "$_file" "$_slug" "$_ttl" "$_method" "$_export")
  else
    _resp=$(api_post_new "$_content" "$_slug" "$_ttl" "$_type" "$_convert" "$_method" "$_export")
  fi
  _url=$(printf '%s' "$_resp" | jq -r '.surl // empty')
  [ -n "$_url" ] || die "no URL returned from API; response: $_resp"

  clipboard_copy "$_url" && printf 'Copied to clipboard: %s\n' "$_url" >&2

  if [ "$_export" = "1" ]; then
    print_json "$_resp"
  else
    printf '%s\n' "$_url"
  fi
}

cmd_ls() {
  _export=0
  while [ $# -gt 0 ]; do
    case "$1" in
      -x|--export)
        _export=1; shift ;;
      --)
        shift; break ;;
      -*)
        die "unknown option '$1'. Try: post help" ;;
      *)
        break ;;
    esac
  done
  print_json "$(api_ls "${1:-}" "$_export")"
}

cmd_export() {
  print_json "$(api_export "${1:-}")"
}

cmd_rm() {
  _export=0
  while [ $# -gt 0 ]; do
    case "$1" in
      -x|--export)
        _export=1; shift ;;
      --)
        shift; break ;;
      -*)
        die "unknown option '$1'. Try: post help" ;;
      *)
        break ;;
    esac
  done
  [ -n "$1" ] || die "usage: post rm [-x|--export] <path>"
  print_json "$(api_rm "$1" "$_export")"
}

cmd_help() {
  cat <<'EOF'
post - paste & short-URL manager

Usage:
  post new [opts] <text...>    Upload text
  post new [opts] -f <file>    Upload file contents
  post new [opts]              Upload clipboard contents (no -f, no text, no stdin)
  echo "..." | post [new]      Upload from stdin
  post ls                      List all posts (truncated text)
  post ls <path>               Show a specific post
  post ls -x <path>            Show a specific post with full content
  post export                  Export all posts with full text
  post export <path>           Export one post with full content
  post rm <path>               Delete a post
  post rm -x <path>            Delete a post and return full content
  post help | -h | --help      Show this help

Options for 'new':
  -f, --file <path>              Read content from file
  -s, --slug <path>              Custom slug/path (default: auto-generated)
  -t, --ttl <minutes>            Expiration time in minutes (default: never)
  -u, --update                   Overwrite if slug already exists (uses PUT)
  -y, --no-confirm               Skip confirmation prompt
  -x, --export                   Return full create/update response
  -c, --convert <mode>           Convert/type before uploading:
                                   html    → set type to html
                                   md2html → convert Markdown to HTML (type: html)
                                   url     → set type to url
                                   text    → set type to text
                                   qrcode  → convert content to QR code
                                   file    → upload binary file (requires -f)

Options for 'ls' and 'rm':
  -x, --export                   Return full content

Environment variables:
  POST_HOST    Base endpoint URL (e.g. https://example.com)
  POST_TOKEN   Bearer token

Examples:
  post new hello world
  post new -f ~/notes.txt
  post new -s mycode -f script.sh
  post new -t 60 "expires in 1 hour"
  post new -y "quick note"
  post new                          # uploads clipboard
  echo "piped" | post
  echo "piped" | post new -s myslug
  post ls
  post ls myslug
  post ls -x myslug
  post rm myslug
  post rm -x myslug
  post export myslug

EOF
}

# ══════════════════════════════════════════════════════════════
# Dispatch
# ══════════════════════════════════════════════════════════════

require_cmds

# If stdin is a pipe and first arg is NOT a subcommand → treat as 'new'
if [ ! -t 0 ]; then
  case "${1:-}" in
    new|ls|export|rm|help|--help|-h) ;;   # recognised subcommand, fall through
    *) set -- new "$@" ;;           # prepend 'new'
  esac
fi

cmd="${1:-help}"
[ $# -gt 0 ] && shift

case "$cmd" in
  new)              cmd_new    "$@" ;;
  ls)               cmd_ls     "$@" ;;
  export)           cmd_export "$@" ;;
  rm)               cmd_rm     "$@" ;;
  help|--help|-h)   cmd_help        ;;
  *)  die "unknown command '${cmd}'. Try: post help" ;;
esac
